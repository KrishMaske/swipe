{
  "expo": {
    "name": "swipe",
    "slug": "swipe",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./images/AppIcons/playstore.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "icon": "./images/AppIcons/appstore.png",
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": [
          "location",
          "remote-notification",
          "location",
          "remote-notification"
        ],
        "NSLocationWhenInUseUsageDescription": "SwipeSmart uses your location while the app is open to recommend the best card for nearby merchants.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "SwipeSmart uses your location in the background to suggest the best card when you arrive at stores, restaurants, and travel locations.",
        "NSLocationAlwaysUsageDescription": "SwipeSmart uses your location in the background to suggest the best card when you arrive at stores, restaurants, and travel locations.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.krishmaske.swipe"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./images/AppIcons/playstore.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "POST_NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./images/AppIcons/playstore.png"
    },
    "scheme": "swipe",
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "SwipeSmart uses your location while the app is open to recommend the best card for nearby merchants.",
          "locationAlwaysAndWhenInUsePermission": "SwipeSmart uses your location in the background to recommend the best card when you arrive at merchants.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      "expo-notifications",
      "expo-web-browser",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "5f85b5fa-4f29-438d-a683-95225be18f8a"
      }
    }
  }
}
